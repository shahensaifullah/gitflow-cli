# ══════════════════════════════════════════════
#  .gitignore — smart-git-push
# ══════════════════════════════════════════════

# ── macOS ─────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.AppleDouble
.LSOverride
Icon?

# ── VS Code ───────────────────────────────────
.vscode/
.vscode/settings.json
.vscode/tasks.json
.vscode/launch.json
.vscode/extensions.json
.vscode/*.code-snippets
*.code-workspace

# ── PyCharm / JetBrains ───────────────────────
.idea/
.idea/*.xml
.idea/workspace.xml
.idea/tasks.xml
.idea/shelf/
*.iml
*.ipr
*.iws
out/
.idea_modules/

# ── Vim / Neovim ──────────────────────────────
*.swp
*.swo
*~
.netrwhist
Session.vim
.vim/

# ── Emacs ─────────────────────────────────────
*~
\#*\#
.\#*
*.elc

# ── Sublime Text ──────────────────────────────
*.sublime-project
*.sublime-workspace

# ── Logs ──────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS generated ──────────────────────────────
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ── Temp / backup files ───────────────────────
*.tmp
*.temp
*.bak
*.orig
*.rej

# ── Test output ───────────────────────────────
coverage/
.coverage
*.cover
htmlcov/

# ── Node (if ever needed) ─────────────────────
node_modules/
package-lock.json

# ── Python (if ever needed) ───────────────────
__pycache__/
*.py[cod]
*.pyo
.env
.venv
venv/
ENV/

# ── gpush local history (personal, not shared) ─
.gitflow_history